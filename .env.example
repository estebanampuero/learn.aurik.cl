# Copia a .env y rellena. NO subas .env a git.
ANTHROPIC_API_KEY=sk-ant-...

# Modelo del tutor. Haiku 4.5 = barato (default). Para más calidad: claude-opus-4-8
DEUTSCH_TUTOR_MODEL=claude-haiku-4-5

# En el VPS: pon la URL pública del backend (ej. https://tutor-api.tudominio.com)
NEXT_PUBLIC_API_URL=http://localhost:8000

# En el VPS, restringe CORS al dominio del frontend (ej. https://tutor.tudominio.com)
CORS_ORIGINS=*

# ─── Reutilizar el Whisper que ya tienes en el VPS (elige UNA opción) ───────
# OPCIÓN B (recomendada): URL de tu servicio Whisper compartido (urgencias-er).
#   Si la pones, deutsch-tutor NO carga el modelo: le pega por HTTP.
STT_SERVICE_URL=
# OPCIÓN A: misma carpeta de caché de modelos que ya tienes descargada.
#   (En Docker, además monta ese path como volumen — ver docker-compose.yml.)
WHISPER_DOWNLOAD_ROOT=
WHISPER_SIZE=small
